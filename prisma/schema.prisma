generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model with relations
model User {
  id            String         @id @default(uuid())
  email         String?        @unique
  passwordHash  String?
  walletAddress String?        @unique
  fullName      String?
  points        Int            @default(0)
  isAccessGranted Boolean      @default(false)
  
  // Referral System
  referralCode  String?        @unique
  referrerId    String?
  referrer      User?          @relation("UserReferrals", fields: [referrerId], references: [id])
  referrals     User[]         @relation("UserReferrals")
  referralCount Int            @default(0)
  
  billing       BillingState?
  usageLogs     UsageLog[]
  payments      Payment[]
  apiKeys       APIKey[]
  
  // Campaign System
  campaignProgress    CampaignProgress?
  feedbackSubmissions FeedbackSubmission[]
  earlyAccessCodes    EarlyAccessCode[]    @relation("GeneratedCodes")
  
  updatedAt     DateTime       @updatedAt
  createdAt     DateTime       @default(now())
}

// ─── CAMPAIGN SYSTEM ──────────────────────────────────────

// Tracks a user's campaign progress: social tasks, unlocked sections, investor status
model CampaignProgress {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  
  // Social tasks completed (stored as JSON array of task keys)
  completedTasks  String   @default("[]") // JSON: ["follow_x", "follow_cmc", ...]
  
  // User's X (Twitter) handle for verification
  twitterHandle   String?
  
  // Which sections the user has unlocked (0 = none, 1 = chat, 2 = market, etc.)
  unlockedStage   Int      @default(0)
  
  // Early access code redeemed
  hasRedeemedCode Boolean  @default(false)
  
  // Investor bypass — full access, no gating
  isInvestor      Boolean  @default(false)
  
  // Weekly feedback tracking
  weeklyFeedbackCount Int  @default(0)
  lastFeedbackWeek    Int  @default(0) // ISO week number of last feedback
  totalXFeedbacks     Int  @default(0) // Max 10 over entire campaign
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Stores each feedback submission (tweet link) per section per user
model FeedbackSubmission {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  section     String   // "chat", "market", "smart-contracts", "nft", "wallet-intel"
  platform    String   @default("twitter") // "twitter", "telegram", "discord"
  tweetUrl    String   // The tweet/post link
  
  status      String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  reviewedAt  DateTime?
  reviewNote  String?  // Admin note on rejection
  
  pointsAwarded Int    @default(0)
  
  createdAt   DateTime @default(now())
}

// Early Access Codes — generated by users (500 PTS) or pre-made for investors
model EarlyAccessCode {
  id          String   @id @default(uuid())
  code        String   @unique
  
  type        String   @default("EARNED") // "EARNED" (user spent 500 PTS) or "INVESTOR"
  
  // Who generated/owns this code
  generatedById String?
  generatedBy   User?  @relation("GeneratedCodes", fields: [generatedById], references: [id])
  
  // Who redeemed this code (could be same user or different)
  redeemedById  String?
  redeemedAt    DateTime?
  
  isUsed      Boolean  @default(false)
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
}

// Billing State Logic
model BillingState {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  plan            String   @default("free") // "free", "pro", "enterprise"
  tier            String   @default("FREE") // "FREE", "PAID" (redundant but consistent with request)
  credits         Int      @default(20)
  dailyUsageCount Int      @default(0)
  lastResetAt     DateTime @default(now())
}

// Usage Ledger
model UsageLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // "AI_MESSAGE", "API_REQUEST"
  cost      Int
  timestamp DateTime @default(now())
}

// Detailed Payment Tracking (X402)
model Payment {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  walletAddress String   // Can be linked even if no user ID yet
  amount        Float
  currency      String   @default("USDC")
  network       String   @default("Base Sepolia")
  txHash        String   @unique
  status        String   @default("PENDING") // "PENDING", "COMPLETED", "FAILED"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// API Keys for External Access
model APIKey {
  id          String   @id @default(uuid())
  key         String   @unique @default(uuid()) // The actual secret key
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String?  // e.g. "My production key"
  usageCount  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
}

// Access Control System
model AccessCode {
  id        String   @id @default(uuid())
  code      String   @unique // e.g., "AI-BETA-2024"
  maxUses   Int      @default(100)
  usedCount Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Waitlist {
  id            String   @id @default(uuid())
  email         String   @unique
  walletAddress String?
  telegram      String?
  twitter       String?
  reason        String?
  status        String   @default("PENDING") // "PENDING", "APPROVED", "INVITED"
  createdAt     DateTime @default(now())
}
